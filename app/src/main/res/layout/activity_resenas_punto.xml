<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/toolbarResenas"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingHorizontal="12dp">

        <ImageButton
            android:id="@+id/btnAtrasResenas"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#2D3436"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reseñas y Opiniones"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2D3436"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResenas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbarResenas"
        android:padding="16dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/txtResenasVacio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="💬 Nadie ha dejado una opinión aún.\n¡Comparte tu experiencia!"
        android:gravity="center"
        android:textColor="#A0A0A0"
        android:textSize="15sp"
        android:visibility="gone"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabEscribirResena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:contentDescription="Escribir Reseña"
        android:backgroundTint="#84B026"
        app:tint="#FFFFFF"
        app:srcCompat="@android:drawable/ic_menu_edit" />

</RelativeLayout>