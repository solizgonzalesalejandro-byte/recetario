<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sugerir Nueva Categoría"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#2D3436"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ayúdanos a expandir el mapa ecológico de Cochabamba."
        android:textSize="14sp"
        android:textColor="#636E72"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre de la categoría (Ej: Neumáticos)"
        android:layout_marginBottom="16dp"
        app:startIconDrawable="@android:drawable/ic_menu_sort_by_size"
        app:startIconTint="#84B026"
        app:boxStrokeColor="#84B026"
        app:hintTextColor="#84B026">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/fNombreCategoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="¿Por qué es importante esta categoría?"
        android:layout_marginBottom="16dp"
        app:startIconDrawable="@android:drawable/ic_menu_help"
        app:startIconTint="#84B026"
        app:boxStrokeColor="#84B026"
        app:hintTextColor="#84B026">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/fJustificacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lines="3"
            android:gravity="top|start"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Color distintivo sugerido:"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/fColorGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <RadioButton android:id="@+id/rbVerde" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Verde" android:checked="true"/>
        <RadioButton android:id="@+id/rbAzul" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Azul"/>
        <RadioButton android:id="@+id/rbNaranja" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Naranja"/>
    </RadioGroup>

    <Button
        android:id="@+id/btnEnviarCategoria"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="ENVIAR SUGERENCIA"
        android:backgroundTint="#84B026"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:cornerRadius="12dp"
        app:icon="@android:drawable/ic_menu_send"
        app:iconGravity="textStart"
        app:iconTint="@android:color/white"/>

</LinearLayout>